@page "/b2e/forgot-password"
@model B2eForgotPasswordModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>B2E Admin – 忘記密碼</title>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/b2e.css">
  <style>
    body { background: #f0f2f5; display:flex; align-items:center; justify-content:center; min-height:100vh; }
    .fp-card { background:white; border-radius:16px; padding:40px; width:100%; max-width:420px; box-shadow:0 4px 24px rgba(0,0,0,.1); }
    .fp-input { width:100%; padding:10px 14px; border:1.5px solid #ddd; border-radius:8px; font-size:.95rem; box-sizing:border-box; }
  </style>
</head>
<body>
<div id="b2e-fp-app" v-cloak>
  <div class="fp-card">
    <div style="text-align:center;margin-bottom:28px">
      <div style="font-size:2.5rem">🔑</div>
      <h2 style="margin:8px 0 4px;color:#1a252f">{{ t('auth.forgotPasswordTitle') }}</h2>
      <p style="color:#7f8c8d;font-size:.9rem">{{ t('auth.forgotPasswordDesc') }}</p>
    </div>

    <div v-if="!sent">
      <div style="margin-bottom:16px">
        <label style="font-size:.9rem;font-weight:500;display:block;margin-bottom:6px">Email</label>
        <input v-model="email" type="email" class="fp-input" @@keyup.enter="submit">
        <p v-if="error" style="color:#e74c3c;font-size:.85rem;margin:6px 0 0">{{ error }}</p>
      </div>
      <button @@click="submit" :disabled="loading"
              style="width:100%;padding:12px;background:#3498db;color:white;border:none;border-radius:8px;font-size:1rem;font-weight:600;cursor:pointer">
        {{ loading ? t('common.loading') : t('auth.sendResetLink') }}
      </button>
    </div>

    <div v-else style="text-align:center">
      <div style="font-size:2.5rem;margin-bottom:12px">📬</div>
      <p style="font-weight:600">{{ t('auth.resetLinkSent') }}</p>
      <p style="color:#7f8c8d;font-size:.88rem">{{ t('auth.resetLinkSentDesc') }}</p>
    </div>

    <div style="text-align:center;margin-top:20px">
      <a href="/b2e/login" style="color:#3498db;font-size:.9rem;text-decoration:none">← {{ t('auth.backToLogin') }}</a>
    </div>
  </div>
</div>

<script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
<script src="https://unpkg.com/vue-i18n@9/dist/vue-i18n.global.prod.js"></script>
<script src="/js/b2e-i18n.js"></script>
<script src="/js/b2e-api.js"></script>
<script>
const { createApp, ref } = Vue;
const { createI18n }     = VueI18n;
const storedLocale = localStorage.getItem('b2eLocale') || 'zh-TW';
const i18n = createI18n({ legacy: false, locale: storedLocale, messages: b2eMessages });

createApp({
  setup() {
    const { t } = i18n.global;
    const email   = ref('');
    const loading = ref(false);
    const sent    = ref(false);
    const error   = ref('');

    async function submit() {
      error.value = '';
      if (!email.value) { error.value = t('auth.emailRequired'); return; }
      loading.value = true;
      try {
        await b2eApi.post('/auth/forgot-password', { email: email.value });
        sent.value = true;
      } catch { error.value = t('common.error'); }
      finally { loading.value = false; }
    }

    return { t, email, loading, sent, error, submit };
  }
}).use(i18n).mount('#b2e-fp-app');
</script>
</body>
</html>
