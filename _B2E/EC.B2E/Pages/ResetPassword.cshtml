@page "/b2e/reset-password"
@model B2eResetPasswordModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>B2E Admin – 重設密碼</title>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/b2e.css">
  <style>
    body { background: #f0f2f5; display:flex; align-items:center; justify-content:center; min-height:100vh; }
    .rp-card { background:white; border-radius:16px; padding:40px; width:100%; max-width:420px; box-shadow:0 4px 24px rgba(0,0,0,.1); }
    .rp-input { width:100%; padding:10px 14px; border:1.5px solid #ddd; border-radius:8px; font-size:.95rem; box-sizing:border-box; }
  </style>
</head>
<body>
<div id="b2e-rp-app" v-cloak>
  <div class="rp-card">
    <div style="text-align:center;margin-bottom:28px">
      <div style="font-size:2.5rem">🔐</div>
      <h2 style="margin:8px 0 4px;color:#1a252f">{{ t('auth.resetPasswordTitle') }}</h2>
    </div>

    <div v-if="!done && !invalid">
      <div style="margin-bottom:14px">
        <label style="font-size:.9rem;font-weight:500;display:block;margin-bottom:6px">{{ t('auth.newPassword') }}</label>
        <input v-model="newPassword" type="password" class="rp-input">
      </div>
      <div style="margin-bottom:20px">
        <label style="font-size:.9rem;font-weight:500;display:block;margin-bottom:6px">{{ t('auth.confirmPassword') }}</label>
        <input v-model="confirmPassword" type="password" class="rp-input">
      </div>
      <p v-if="error" style="color:#e74c3c;font-size:.85rem;margin:-12px 0 12px">{{ error }}</p>
      <button @@click="submit" :disabled="loading"
              style="width:100%;padding:12px;background:#3498db;color:white;border:none;border-radius:8px;font-size:1rem;font-weight:600;cursor:pointer">
        {{ loading ? t('common.loading') : t('auth.resetPassword') }}
      </button>
    </div>

    <div v-if="done" style="text-align:center">
      <div style="font-size:2.5rem;margin-bottom:12px">✅</div>
      <p style="font-weight:600">{{ t('auth.resetSuccess') }}</p>
      <a href="/b2e/login" style="display:inline-block;margin-top:16px;color:#3498db">{{ t('auth.backToLogin') }}</a>
    </div>

    <div v-if="invalid" style="text-align:center">
      <div style="font-size:2.5rem;margin-bottom:12px">❌</div>
      <p style="color:#e74c3c;font-weight:600">{{ t('auth.invalidToken') }}</p>
      <a href="/b2e/forgot-password" style="display:inline-block;margin-top:16px;color:#3498db">{{ t('auth.forgotPassword') }}</a>
    </div>
  </div>
</div>

<script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
<script src="https://unpkg.com/vue-i18n@9/dist/vue-i18n.global.prod.js"></script>
<script src="/js/b2e-i18n.js"></script>
<script src="/js/b2e-api.js"></script>
<script>
const { createApp, ref } = Vue;
const { createI18n }     = VueI18n;
const storedLocale = localStorage.getItem('b2eLocale') || 'zh-TW';
const i18n = createI18n({ legacy: false, locale: storedLocale, messages: b2eMessages });

createApp({
  setup() {
    const { t } = i18n.global;
    const token           = new URLSearchParams(location.search).get('token') || '';
    const newPassword     = ref('');
    const confirmPassword = ref('');
    const loading         = ref(false);
    const done            = ref(false);
    const invalid         = ref(!token);
    const error           = ref('');

    async function submit() {
      error.value = '';
      if (newPassword.value.length < 4) { error.value = t('changePassword.tooShort'); return; }
      if (newPassword.value !== confirmPassword.value) { error.value = t('auth.passwordMismatch'); return; }
      loading.value = true;
      try {
        const res = await b2eApi.post('/auth/reset-password', { token, newPassword: newPassword.value });
        if (res.success) done.value = true;
        else { error.value = res.message || t('auth.invalidToken'); invalid.value = true; }
      } catch { error.value = t('common.error'); }
      finally { loading.value = false; }
    }

    return { t, newPassword, confirmPassword, loading, done, invalid, error, submit };
  }
}).use(i18n).mount('#b2e-rp-app');
</script>
</body>
</html>
