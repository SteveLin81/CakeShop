@page "/b2e/admin/roles"
@model RolesAdminModel
@{ Layout = "_AdminLayout"; ViewData["Title"] = "角色權限管理"; ViewData["TitleKey"] = "role.title"; }

<div class="b2e-page-header">
  <div>
    <div class="b2e-page-title">{{ t('role.title') }}</div>
    <div class="b2e-page-subtitle">{{ t('common.total') }} {{ roles.length }} {{ t('common.records') }}</div>
  </div>
  <button v-if="hasPermission('roles')" class="btn-primary" @@click="openCreate">＋ {{ t('common.add') }}</button>
</div>

<div class="b2e-card">
  <el-table :data="roles" v-loading="loading" stripe style="width:100%">
    <el-table-column :label="t('role.name')" width="140">
      <template #default="{ row }">{{ row.name }}</template>
    </el-table-column>
    <el-table-column :label="t('role.description')" min-width="180">
      <template #default="{ row }">{{ row.description }}</template>
    </el-table-column>
    <el-table-column :label="t('role.permissions')" min-width="280">
      <template #default="{ row }">
        <span v-for="p in row.permissions" :key="p"
              style="display:inline-block;background:#e8f4fd;color:#1a73e8;border-radius:4px;padding:2px 8px;margin:2px;font-size:.8rem">
          {{ permLabel(p) }}
        </span>
      </template>
    </el-table-column>
    <el-table-column :label="t('common.actions')" width="200" fixed="right">
      <template #default="{ row }">
        <button v-if="hasPermission('roles')" class="btn-outline" style="margin-right:8px" @@click="openEdit(row)">✏️ {{ t('common.edit') }}</button>
        <el-popconfirm v-if="hasPermission('roles')" :title="t('role.deleteConfirm')" @@confirm="doDelete(row.id)">
          <template #reference><button class="btn-danger">🗑 {{ t('common.delete') }}</button></template>
        </el-popconfirm>
      </template>
    </el-table-column>
  </el-table>
</div>

<!-- Add/Edit Dialog -->
<el-dialog v-model="dialogVisible" :title="isEdit ? t('role.editTitle') : t('role.newTitle')"
           width="560px" :close-on-click-modal="false">
  <el-form label-width="90px">
    <el-form-item :label="t('role.name')">
      <el-input v-model="form.name" :placeholder="t('role.nameReq')" />
    </el-form-item>
    <el-form-item :label="t('role.description')">
      <el-input v-model="form.description" />
    </el-form-item>
    <el-form-item :label="t('role.permissions')">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        <el-checkbox v-for="p in allPerms" :key="p.key" v-model="form.permissions" :label="p.key">
          {{ p.label }}
        </el-checkbox>
      </div>
    </el-form-item>
  </el-form>
  <template #footer>
    <button class="btn-outline" @@click="dialogVisible=false">{{ t('common.cancel') }}</button>
    <button class="btn-primary" style="margin-left:8px" @@click="submitForm" :disabled="saving">
      {{ saving ? t('common.loading') : t('common.save') }}
    </button>
  </template>
</el-dialog>

@section Scripts {
<script>
const { createApp, ref, reactive, computed, onMounted } = Vue;
createApp({
  setup() {
    const common   = useB2eCommon();
    const loading  = ref(false);
    const saving   = ref(false);
    const roles    = ref([]);
    const dialogVisible = ref(false);
    const isEdit   = ref(false);
    const editId   = ref(null);
    const form     = reactive({ name: '', description: '', permissions: [] });

    const allPerms = computed(() => [
      { key: 'dashboard',     label: common.t('role.permissionDashboard')     },
      { key: 'products',      label: common.t('role.permissionProducts')      },
      { key: 'categories',    label: common.t('role.permissionCategories')    },
      { key: 'announcements', label: common.t('role.permissionAnnouncements') },
      { key: 'members',       label: common.t('role.permissionMembers')       },
      { key: 'homepage',      label: common.t('role.permissionHomepage')      },
      { key: 'roles',         label: common.t('role.permissionRoles')         },
      { key: 'admins',        label: common.t('role.permissionAdmins')        },
    ]);

    function permLabel(key) {
      return allPerms.value.find(p => p.key === key)?.label || key;
    }

    async function loadData() {
      loading.value = true;
      try { roles.value = (await b2eApi.getRoles()).data ?? []; }
      catch { common.showToast(common.t('common.error')); }
      finally { loading.value = false; }
    }

    function openCreate() {
      isEdit.value = false; editId.value = null;
      Object.assign(form, { name: '', description: '', permissions: [] });
      dialogVisible.value = true;
    }

    function openEdit(row) {
      isEdit.value = true; editId.value = row.id;
      Object.assign(form, { name: row.name, description: row.description, permissions: [...row.permissions] });
      dialogVisible.value = true;
    }

    async function submitForm() {
      if (!form.name.trim()) { common.showToast(common.t('role.nameReq')); return; }
      saving.value = true;
      try {
        const res = isEdit.value
          ? await b2eApi.updateRole(editId.value, { ...form })
          : await b2eApi.createRole({ ...form });
        if (res.success) { common.showToast(common.t('common.success')); dialogVisible.value = false; await loadData(); }
        else common.showToast(res.message || common.t('common.error'));
      } catch { common.showToast(common.t('common.error')); }
      finally { saving.value = false; }
    }

    async function doDelete(id) {
      try {
        const res = await b2eApi.deleteRole(id);
        if (res.success) { common.showToast(common.t('common.success')); await loadData(); }
        else common.showToast(res.message || common.t('common.error'));
      } catch { common.showToast(common.t('common.error')); }
    }

    onMounted(async () => { await common.checkAuth(); await loadData(); });

    return { ...common, loading, saving, roles, dialogVisible, isEdit, form, allPerms, permLabel,
             openCreate, openEdit, submitForm, doDelete };
  }
}).use(b2eI18n).use(ElementPlus).mount('#b2e-app');
</script>
}
