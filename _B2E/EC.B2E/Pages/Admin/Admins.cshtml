@page "/b2e/admin/admins"
@model AdminsAdminModel
@{ Layout = "_AdminLayout"; ViewData["Title"] = "後台帳號管理"; ViewData["TitleKey"] = "admin.title"; }

<div class="b2e-page-header">
  <div>
    <div class="b2e-page-title">{{ t('admin.title') }}</div>
    <div class="b2e-page-subtitle">{{ t('common.total') }} {{ admins.length }} {{ t('common.records') }}</div>
  </div>
  <button v-if="hasPermission('admins')" class="btn-primary" @@click="openCreate">＋ {{ t('common.add') }}</button>
</div>

<div class="b2e-card">
  <el-table :data="admins" v-loading="loading" stripe style="width:100%" :key="locale">
    <el-table-column :label="t('admin.username')" width="140">
      <template #default="{ row }">{{ row.username }}</template>
    </el-table-column>
    <el-table-column :label="t('admin.displayName')" width="140">
      <template #default="{ row }">{{ row.displayName }}</template>
    </el-table-column>
    <el-table-column :label="t('admin.email')" min-width="180">
      <template #default="{ row }">{{ row.email }}</template>
    </el-table-column>
    <el-table-column prop="roleName" :label="t('admin.role')" width="140">
      <template #default="{ row }">
        <span v-if="row.roleName"
              style="display:inline-block;background:#e8f4fd;color:#1a73e8;border-radius:4px;padding:2px 8px;font-size:.8rem">
          {{ localRoleName(row) }}
        </span>
        <span v-else style="color:#999;font-size:.8rem">{{ t('admin.noRole') }}</span>
      </template>
    </el-table-column>
    <el-table-column :label="t('admin.mustChangePwd')" width="120">
      <template #default="{ row }">
        <el-tag :type="row.mustChangePassword ? 'warning' : 'success'" size="small">
          {{ row.mustChangePassword ? t('common.yes') : t('common.no') }}
        </el-tag>
      </template>
    </el-table-column>
    <el-table-column :label="t('common.actions')" width="200" fixed="right">
      <template #default="{ row }">
        <button v-if="hasPermission('admins')" class="btn-outline" style="margin-right:8px" @@click="openEdit(row)">✏️ {{ t('common.edit') }}</button>
        <el-popconfirm v-if="hasPermission('admins')" :title="t('admin.deleteConfirm')" @@confirm="doDelete(row.id)">
          <template #reference><button class="btn-danger">🗑 {{ t('common.delete') }}</button></template>
        </el-popconfirm>
      </template>
    </el-table-column>
  </el-table>
</div>

<!-- Add/Edit Dialog -->
<el-dialog v-model="dialogVisible" :title="isEdit ? t('admin.editTitle') : t('admin.newTitle')"
           width="480px" :close-on-click-modal="false">
  <el-form label-width="100px">
    <el-form-item :label="t('admin.username')" required>
      <el-input v-model="form.username" :disabled="isEdit" :placeholder="t('admin.usernameReq')" />
    </el-form-item>
    <el-form-item label="使用者名稱" :required="!isEdit">
      <el-input v-model="form.displayName" placeholder="請輸入顯示名稱" />
    </el-form-item>
    <el-form-item label="Email" required>
      <el-input v-model="form.email" type="email" placeholder="example@company.com" />
      <div v-if="formErrors.email" style="color:#f56c6c;font-size:12px;margin-top:4px">{{ formErrors.email }}</div>
    </el-form-item>
    <el-form-item :label="t('admin.role')">
      <el-select v-model="form.roleId" clearable style="width:100%">
        <el-option v-for="r in roles" :key="r.id" :label="r.name" :value="r.id" />
      </el-select>
    </el-form-item>
    <el-form-item v-if="!isEdit" style="margin-bottom:0">
      <el-alert :title="t('admin.defaultPwd')" type="info" :closable="false" show-icon />
    </el-form-item>
  </el-form>
  <template #footer>
    <button class="btn-outline" @@click="dialogVisible=false">{{ t('common.cancel') }}</button>
    <button class="btn-primary" style="margin-left:8px" @@click="submitForm" :disabled="saving">
      {{ saving ? t('common.loading') : t('common.save') }}
    </button>
  </template>
</el-dialog>

@section Scripts {
<script>
const { createApp, ref, reactive, onMounted } = Vue;
createApp({
  setup() {
    const common   = useB2eCommon();
    const { locale } = common;
    const loading  = ref(false);
    const saving   = ref(false);
    const admins   = ref([]);
    const roles    = ref([]);
    const dialogVisible = ref(false);
    const isEdit   = ref(false);
    const editId   = ref(null);
    const form       = reactive({ username: '', displayName: '', email: '', roleId: null });
    const formErrors = reactive({ email: '' });

    async function loadData() {
      loading.value = true;
      try {
        const [ar, rr] = await Promise.all([b2eApi.getAdmins(), b2eApi.getRoles()]);
        admins.value = ar.data ?? [];
        roles.value  = rr.data ?? [];
      } catch { common.showToast(common.t('common.error')); }
      finally { loading.value = false; }
    }

    function localRoleName(row) {
      const role = roles.value.find(r => r.id === row.roleId);
      if (!role) return row.roleName || '';
      const map = {
        'en': role.nameEn, 'ja': role.nameJa, 'zh-CN': role.nameZhCn,
        'th': role.nameTh, 'ko': role.nameKo, 'vi': role.nameVi, 'ms': role.nameMs
      };
      return map[locale.value] || role.name;
    }

    function openCreate() {
      isEdit.value = false; editId.value = null;
      Object.assign(form, { username: '', displayName: '', email: '', roleId: null });
      Object.assign(formErrors, { email: '' });
      dialogVisible.value = true;
    }

    function openEdit(row) {
      isEdit.value = true; editId.value = row.id;
      Object.assign(form, { username: row.username, displayName: row.displayName || '', email: row.email || '', roleId: row.roleId || null });
      Object.assign(formErrors, { email: '' });
      dialogVisible.value = true;
    }

    async function submitForm() {
      Object.assign(formErrors, { email: '' });
      if (!form.username.trim()) { common.showToast(common.t('admin.usernameReq')); return; }
      if (!form.displayName.trim() && !isEdit.value) { common.showToast('使用者名稱為必填'); return; }
      if (!isEdit.value) {
        if (!form.email.trim()) { formErrors.email = 'Email 為必填'; return; }
        if (!/^[^@@\s]+@@[^@@\s]+\.[^@@\s]+$/.test(form.email)) { formErrors.email = 'Email 格式不正確'; return; }
      }
      saving.value = true;
      try {
        const res = isEdit.value
          ? await b2eApi.updateAdmin(editId.value, { displayName: form.displayName, email: form.email, roleId: form.roleId })
          : await b2eApi.createAdmin({ username: form.username, displayName: form.displayName, email: form.email, roleId: form.roleId });
        if (res.success) { common.showToast(common.t('common.success')); dialogVisible.value = false; await loadData(); }
        else common.showError(res.message || common.t('common.error'));
      } catch { common.showError(common.t('common.error')); }
      finally { saving.value = false; }
    }

    async function doDelete(id) {
      try {
        const res = await b2eApi.deleteAdmin(id);
        if (res.success) { common.showToast(common.t('common.success')); await loadData(); }
        else common.showError(res.message || common.t('common.error'));
      } catch { common.showError(common.t('common.error')); }
    }

    onMounted(async () => { await common.requirePermission('admins'); await loadData(); });

    return { ...common, loading, saving, admins, roles, dialogVisible, isEdit, form, formErrors,
             openCreate, openEdit, submitForm, doDelete, formatDate, localRoleName };
  }
}).use(b2eI18n).use(ElementPlus).mount('#b2e-app');
</script>
}
