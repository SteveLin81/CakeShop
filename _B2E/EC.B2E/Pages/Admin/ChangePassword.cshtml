@page "/b2e/admin/change-password"
@model ChangePasswordAdminModel
@{ Layout = "_AdminLayout"; ViewData["Title"] = "修改密碼"; ViewData["TitleKey"] = "changePassword.title"; }

<div class="b2e-page-header">
  <div>
    <div class="b2e-page-title">{{ t('changePassword.title') }}</div>
    <div class="b2e-page-subtitle">{{ t('changePassword.subtitle') }}</div>
  </div>
</div>

<div class="b2e-card" style="max-width:480px">
  <el-alert v-if="mustChangePassword" :title="t('changePassword.firstLogin')" type="warning"
            :closable="false" show-icon style="margin-bottom:20px" />

  <el-form label-width="120px">
    <el-form-item :label="t('changePassword.current')">
      <el-input v-model="form.currentPassword" type="password" show-password />
    </el-form-item>
    <el-form-item :label="t('changePassword.newPwd')">
      <el-input v-model="form.newPassword" type="password" show-password />
    </el-form-item>
    <el-form-item :label="t('changePassword.confirm')">
      <el-input v-model="form.confirmPassword" type="password" show-password />
    </el-form-item>
    <el-form-item>
      <button class="btn-primary" @@click="submitForm" :disabled="saving" style="min-width:120px">
        {{ saving ? t('common.loading') : t('changePassword.submit') }}
      </button>
    </el-form-item>
  </el-form>
</div>

@section Scripts {
<script>
const { createApp, ref, reactive, onMounted } = Vue;
createApp({
  setup() {
    const common = useB2eCommon();
    const saving = ref(false);
    const form   = reactive({ currentPassword: '', newPassword: '', confirmPassword: '' });

    async function submitForm() {
      if (!form.currentPassword) { common.showToast(common.t('changePassword.currentReq')); return; }
      if (!form.newPassword)     { common.showToast(common.t('changePassword.newReq'));     return; }
      if (form.newPassword.length < 4) { common.showToast(common.t('changePassword.tooShort')); return; }
      if (form.newPassword !== form.confirmPassword) { common.showToast(common.t('changePassword.notMatch')); return; }

      saving.value = true;
      try {
        const res = await b2eApi.changePassword({
          currentPassword: form.currentPassword,
          newPassword:     form.newPassword,
        });
        if (res.success) {
          common.showToast(common.t('changePassword.success'));
          Object.assign(form, { currentPassword: '', newPassword: '', confirmPassword: '' });
          common.mustChangePassword.value = false;
          setTimeout(() => { location.href = '/b2e/admin'; }, 1200);
        } else {
          common.showToast(res.message || common.t('common.error'));
        }
      } catch { common.showToast(common.t('common.error')); }
      finally { saving.value = false; }
    }

    onMounted(async () => { await common.checkAuth(); });

    return { ...common, saving, form, submitForm };
  }
}).use(b2eI18n).use(ElementPlus).mount('#b2e-app');
</script>
}
