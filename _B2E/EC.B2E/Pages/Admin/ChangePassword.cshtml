@page "/b2e/admin/change-password"
@model ChangePasswordAdminModel
@{ Layout = "_AdminLayout"; ViewData["Title"] = "修改密碼"; ViewData["TitleKey"] = "changePassword.title"; }

<div class="b2e-page-header">
  <div>
    <div class="b2e-page-title">{{ t('changePassword.title') }}</div>
    <div class="b2e-page-subtitle">{{ t('changePassword.subtitle') }}</div>
  </div>
</div>

<div class="b2e-card" style="max-width:480px">
  <div v-if="mustChangePassword"
       style="background:#fdf6ec;border:1px solid #f5a623;border-radius:8px;padding:12px 16px;margin-bottom:20px;color:#8a5700;font-size:.88rem">
    ⚠️ {{ t('changePassword.firstLogin') }}
  </div>

  <div class="b2e-form-group">
    <label class="b2e-form-label">{{ t('changePassword.current') }}</label>
    <input class="b2e-form-input" type="password" v-model="form.currentPassword"
           :placeholder="t('changePassword.current')" autocomplete="current-password">
  </div>
  <div class="b2e-form-group">
    <label class="b2e-form-label">{{ t('changePassword.newPwd') }}</label>
    <input class="b2e-form-input" type="password" v-model="form.newPassword"
           :placeholder="t('changePassword.newPwd')" autocomplete="new-password">
  </div>
  <div class="b2e-form-group">
    <label class="b2e-form-label">{{ t('changePassword.confirm') }}</label>
    <input class="b2e-form-input" type="password" v-model="form.confirmPassword"
           :placeholder="t('changePassword.confirm')" autocomplete="new-password">
  </div>
  <div v-if="errorMsg" class="b2e-form-error" style="margin-bottom:12px">{{ errorMsg }}</div>
  <button class="btn-primary" @@click="submitForm" :disabled="saving" style="min-width:120px">
    {{ saving ? t('common.loading') : t('changePassword.submit') }}
  </button>
</div>

@section Scripts {
<script>
const { createApp, ref, reactive, onMounted } = Vue;
createApp({
  setup() {
    const common   = useB2eCommon();
    const saving   = ref(false);
    const errorMsg = ref('');
    const form     = reactive({ currentPassword: '', newPassword: '', confirmPassword: '' });

    async function submitForm() {
      errorMsg.value = '';
      if (!form.currentPassword) { errorMsg.value = common.t('changePassword.currentReq'); return; }
      if (!form.newPassword)     { errorMsg.value = common.t('changePassword.newReq');     return; }
      if (form.newPassword.length < 4) { errorMsg.value = common.t('changePassword.tooShort'); return; }
      if (form.newPassword !== form.confirmPassword) { errorMsg.value = common.t('changePassword.notMatch'); return; }

      saving.value = true;
      try {
        const res = await b2eApi.changePassword({
          currentPassword: form.currentPassword,
          newPassword:     form.newPassword,
        });
        if (res.success) {
          common.showToast(common.t('changePassword.success'));
          Object.assign(form, { currentPassword: '', newPassword: '', confirmPassword: '' });
          common.mustChangePassword.value = false;
          setTimeout(() => { location.href = '/b2e/admin'; }, 1200);
        } else {
          errorMsg.value = res.message || common.t('common.error');
        }
      } catch { errorMsg.value = common.t('common.error'); }
      finally { saving.value = false; }
    }

    onMounted(async () => { await common.checkAuth(); });

    return { ...common, saving, errorMsg, form, submitForm };
  }
}).use(b2eI18n).use(ElementPlus).mount('#b2e-app');
</script>
}
