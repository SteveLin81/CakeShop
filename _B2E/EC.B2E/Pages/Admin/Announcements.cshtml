@page "/b2e/admin/announcements"
@model AnnouncementsAdminModel
@{ Layout = "_AdminLayout"; ViewData["Title"] = "公告管理"; ViewData["TitleKey"] = "announcement.title"; }

<div class="b2e-page-header">
  <div>
    <div class="b2e-page-title">{{ t('announcement.title') }}</div>
    <div class="b2e-page-subtitle">{{ t('common.total') }} {{ announcements.length }} {{ t('common.records') }}</div>
  </div>
  <button class="btn-primary" @@click="openCreate">＋ {{ t('common.add') }}</button>
</div>

<!-- Table -->
<div class="b2e-card">
  <div class="b2e-toolbar">
    <div class="b2e-toolbar-left">
      <el-input v-model="searchText" :placeholder="t('common.search')" clearable style="width:280px">
        <template #prefix><span>🔍</span></template>
      </el-input>
    </div>
    <div class="b2e-toolbar-right">
      <button class="btn-outline" @@click="loadData">{{ t('common.refresh') }}</button>
    </div>
  </div>

  <el-table :data="filteredAnnouncements" v-loading="loading" stripe style="width:100%">
    <el-table-column :label="t('announcement.content')" min-width="240">
      <template #default="{ row }">
        <div style="white-space:pre-wrap;word-break:break-word;max-height:60px;overflow:hidden">{{ row.content }}</div>
      </template>
    </el-table-column>
    <el-table-column :label="t('announcement.isActive')" width="120">
      <template #default="{ row }">
        <span class="badge" :class="row.isActive ? 'badge-success' : 'badge-danger'">
          {{ row.isActive ? t('common.active') : t('common.inactive') }}
        </span>
      </template>
    </el-table-column>
    <el-table-column :label="t('common.actions')" width="220" fixed="right">
      <template #default="{ row }">
        <button class="btn-outline" style="margin-right:6px" @@click="openEdit(row)">✏️ {{ t('common.edit') }}</button>
        <button v-if="!row.isActive" class="btn-outline" style="margin-right:6px;color:#27ae60;border-color:#27ae60"
                @@click="doActivate(row.id)">✅ {{ t('announcement.activateBtn') }}</button>
        <el-popconfirm :title="t('announcement.deleteConfirm')" @@confirm="doDelete(row.id)">
          <template #reference>
            <button class="btn-danger">🗑 {{ t('common.delete') }}</button>
          </template>
        </el-popconfirm>
      </template>
    </el-table-column>
  </el-table>
</div>

<!-- Add/Edit Dialog -->
<el-dialog v-model="dialogVisible" :title="isEdit ? t('announcement.editTitle') : t('announcement.newTitle')"
           width="720px" :close-on-click-modal="false">
  <el-tabs v-model="activeTab">
    <el-tab-pane :label="t('product.basicTab')" name="basic">
      <el-form-item :label="t('announcement.isActive')">
        <el-switch v-model="form.isActive" />
        <span style="margin-left:8px;font-size:.85rem;color:var(--b2e-muted)">{{ t('announcement.isActiveHint') || '' }}</span>
      </el-form-item>
    </el-tab-pane>
    <el-tab-pane :label="t('product.zhTwTab')" name="zhTW">
      <el-form-item :label="t('announcement.content')">
        <el-input type="textarea" :rows="5" v-model="form.content" />
      </el-form-item>
    </el-tab-pane>
    <el-tab-pane :label="t('product.enTab')" name="en">
      <el-form-item :label="t('announcement.content')">
        <el-input type="textarea" :rows="5" v-model="form.contentEn" />
      </el-form-item>
    </el-tab-pane>
    <el-tab-pane :label="t('product.jaTab')" name="ja">
      <el-form-item :label="t('announcement.content')">
        <el-input type="textarea" :rows="5" v-model="form.contentJa" />
      </el-form-item>
    </el-tab-pane>
    <el-tab-pane :label="t('product.zhCnTab')" name="zhCN">
      <el-form-item :label="t('announcement.content')">
        <el-input type="textarea" :rows="5" v-model="form.contentZhCn" />
      </el-form-item>
    </el-tab-pane>
    <el-tab-pane :label="t('product.thTab')" name="th">
      <el-form-item :label="t('announcement.content')">
        <el-input type="textarea" :rows="5" v-model="form.contentTh" />
      </el-form-item>
    </el-tab-pane>
    <el-tab-pane :label="t('product.koTab')" name="ko">
      <el-form-item :label="t('announcement.content')">
        <el-input type="textarea" :rows="5" v-model="form.contentKo" />
      </el-form-item>
    </el-tab-pane>
    <el-tab-pane :label="t('product.viTab')" name="vi">
      <el-form-item :label="t('announcement.content')">
        <el-input type="textarea" :rows="5" v-model="form.contentVi" />
      </el-form-item>
    </el-tab-pane>
    <el-tab-pane :label="t('product.msTab')" name="ms">
      <el-form-item :label="t('announcement.content')">
        <el-input type="textarea" :rows="5" v-model="form.contentMs" />
      </el-form-item>
    </el-tab-pane>
  </el-tabs>
  <template #footer>
    <button class="btn-outline" @@click="dialogVisible=false">{{ t('common.cancel') }}</button>
    <button class="btn-primary" style="margin-left:8px" @@click="submitForm" :disabled="saving">
      {{ saving ? t('common.loading') : t('common.save') }}
    </button>
  </template>
</el-dialog>

@section Scripts {
<script>
const { createApp, ref, reactive, computed, onMounted } = Vue;
createApp({
  setup() {
    const common        = useB2eCommon();
    const loading       = ref(false);
    const saving        = ref(false);
    const announcements = ref([]);
    const searchText    = ref('');
    const dialogVisible = ref(false);
    const isEdit        = ref(false);
    const editId        = ref(null);
    const activeTab     = ref('basic');
    const form          = reactive(emptyAnnouncementForm());

    const filteredAnnouncements = computed(() => {
      if (!searchText.value.trim()) return announcements.value;
      const q = searchText.value.toLowerCase();
      return announcements.value.filter(a =>
        a.content?.toLowerCase().includes(q) || a.contentEn?.toLowerCase().includes(q));
    });

    async function loadData() {
      loading.value = true;
      try {
        const r = await b2eApi.getAnnouncements();
        announcements.value = r.data ?? [];
      } catch { common.showToast(common.t('common.error')); }
      finally { loading.value = false; }
    }

    function openCreate() {
      isEdit.value = false; editId.value = null; activeTab.value = 'basic';
      Object.assign(form, emptyAnnouncementForm());
      dialogVisible.value = true;
    }

    function openEdit(row) {
      isEdit.value = true; editId.value = row.id; activeTab.value = 'basic';
      Object.assign(form, {
        content: row.content || '', contentEn: row.contentEn || '',
        contentJa: row.contentJa || '', contentZhCn: row.contentZhCn || '',
        contentTh: row.contentTh || '', contentKo: row.contentKo || '',
        contentVi: row.contentVi || '', contentMs: row.contentMs || '',
        isActive: row.isActive,
      });
      dialogVisible.value = true;
    }

    async function submitForm() {
      saving.value = true;
      try {
        const res = isEdit.value
          ? await b2eApi.updateAnnouncement(editId.value, { ...form })
          : await b2eApi.createAnnouncement({ ...form });
        if (res.success) {
          common.showToast(common.t('common.success'));
          dialogVisible.value = false;
          await loadData();
        } else { common.showError(res.message || common.t('common.error')); }
      } catch { common.showError(common.t('common.error')); }
      finally { saving.value = false; }
    }

    async function doActivate(id) {
      try {
        const res = await b2eApi.activateAnnouncement(id);
        if (res.success) { common.showToast(common.t('common.success')); await loadData(); }
        else common.showError(res.message || common.t('common.error'));
      } catch { common.showError(common.t('common.error')); }
    }

    async function doDelete(id) {
      try {
        await b2eApi.deleteAnnouncement(id);
        common.showToast(common.t('common.success'));
        await loadData();
      } catch { common.showError(common.t('common.error')); }
    }

    onMounted(async () => {
      await common.requirePermission('announcements');
      await loadData();
    });

    return { ...common, loading, saving, announcements, searchText, filteredAnnouncements,
             dialogVisible, isEdit, activeTab, form, openCreate, openEdit, submitForm, doActivate, doDelete, formatDate };
  }
}).use(b2eI18n).use(ElementPlus).mount('#b2e-app');
</script>
}
